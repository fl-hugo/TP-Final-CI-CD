# État de déploiement ShopLite — utilisé par rollback.sh et deploy-version.sh
# STABLE_* = dernière version validée (cible du rollback)
# CURRENT_* = version actuellement déployée

API_IMAGE=shoplite-api
FRONTEND_IMAGE=shoplite-frontend

STABLE_API_TAG=starter
STABLE_FRONTEND_TAG=starter

CURRENT_API_TAG=starter
CURRENT_FRONTEND_TAG=starter
