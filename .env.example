NODE_ENV=development
API_PORT=3000
HTTP_PORT=8080
APP_VERSION=starter

API_IMAGE=shoplite-api
FRONTEND_IMAGE=shoplite-frontend
API_TAG=starter
FRONTEND_TAG=starter

POSTGRES_DB=shoplite
POSTGRES_USER=shoplite
POSTGRES_PASSWORD=shoplite_password
DATABASE_URL=postgres://shoplite:shoplite_password@db:5432/shoplite

LOG_LEVEL=info

POSTGRES_CONTAINER=shoplite_db
BACKUP_DIR=backups
BACKUP_RETENTION_COUNT=14
BACKUP_RETENTION_DAYS=30
RESTORE_TEST_DB=shoplite_restore_test
